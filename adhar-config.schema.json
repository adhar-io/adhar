{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Adhar Configuration Schema",
  "description": "Schema for adhar-config.yaml",
  "type": "object",
  "properties": {
    "adhar": {
      "description": "Top-level Adhar configuration key",
      "type": "object",
      "properties": {
        "context": {
          "description": "The kubeconfig context name for the Adhar management cluster",
          "type": "string",
          "minLength": 1
        },
        "defaultHost": {
          "description": "Default host for services if not specified elsewhere",
          "type": "string"
        },
        "defaultHttpPort": {
          "description": "Default HTTP port for services if not specified elsewhere",
          "type": "integer"
        },
        "defaultHttpsPort": {
          "description": "Default HTTPS port for services if not specified elsewhere",
          "type": "integer"
        },
        "defaultRegion": {
          "description": "Default cloud provider region if not specified per environment",
          "type": "string"
        },
        "providerCredentials": {
          "description": "Configuration for accessing cloud provider APIs",
          "type": "object",
          "properties": {
            "do": { "$ref": "#/definitions/providerCredentialsConfig" },
            "gke": { "$ref": "#/definitions/providerCredentialsConfig" },
            "aws": { "$ref": "#/definitions/providerCredentialsConfig" },
            "azure": { "$ref": "#/definitions/providerCredentialsConfig" },
            "civo": { "$ref": "#/definitions/providerCredentialsConfig" }
          },
          "additionalProperties": false
        },
        "environmentTemplates": {
          "description": "Reusable configuration templates for environments",
          "type": "object",
          "additionalProperties": {
            "$ref": "#/definitions/environmentTemplate"
          }
        },
        "environments": {
          "description": "Configuration for specific deployment environments",
          "type": "object",
          "additionalProperties": {
            "$ref": "#/definitions/environmentConfig"
          },
          "minProperties": 1
        }
      },
      "required": [
        "context",
        "defaultHost",
        "defaultHttpPort",
        "defaultHttpsPort",
        "defaultRegion",
        "providerCredentials",
        "environments"
      ],
      "additionalProperties": false
    }
  },
  "required": [
    "adhar"
  ],
  "definitions": {
    "providerCredentialsConfig": {
      "description": "Credentials configuration for a specific provider",
      "type": "object",
      "properties": {
        "type": {
          "description": "Method for retrieving credentials",
          "type": "string",
          "enum": [
            "environment",
            "file"
          ]
        },
        "path": {
          "description": "Filesystem path to the credential file (used if type is 'file')",
          "type": "string"
        },
        "envVar": {
          "description": "Environment variable name containing the credential/token (used if type is 'environment', optional if standard SDK vars are used)",
          "type": "string"
        }
      },
      "required": [
        "type"
      ],
      "if": {
        "properties": { "type": { "const": "file" } },
        "required": ["type"]
      },
      "then": {
        "required": [ "path" ]
      },
      "additionalProperties": false
    },
    "environmentTemplate": {
      "description": "A reusable template for environment configuration",
      "type": "object",
      "properties": {
        "clusterConfig": {
          "description": "Default provider-specific cluster configuration",
          "type": "object",
          "additionalProperties": true
        },
        "coreServices": {
          "description": "Default configuration for core platform services",
          "$ref": "#/definitions/coreServicesSpec"
        },
        "addons": {
          "description": "Default list of addons to install",
          "type": "array",
          "items": {
            "$ref": "#/definitions/addonConfig"
          }
        }
      },
      "additionalProperties": false
    },
    "environmentConfig": {
      "description": "Configuration for a specific environment",
      "type": "object",
      "properties": {
        "template": {
          "description": "Name of an environment template to inherit from (optional)",
          "type": "string"
        },
        "provider": {
          "description": "Infrastructure provider for this environment",
          "type": "string",
          "enum": [
            "kind",
            "do",
            "gke",
            "aws",
            "azure",
            "civo"
          ]
        },
        "region": {
          "description": "Cloud provider region for this environment (required for cloud providers)",
          "type": "string"
        },
        "clusterConfig": {
          "description": "Provider-specific cluster configuration (overrides template)",
          "type": "object",
          "properties": {
            "nodePools": {
              "description": "DigitalOcean-specific node pool configuration",
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "name": { "type": "string" },
                  "size": { "type": "string" },
                  "count": { "type": "integer" },
                  "autoScale": { "type": "boolean" },
                  "minNodes": { "type": "integer" },
                  "maxNodes": { "type": "integer" }
                },
                "required": ["name", "size", "count"]
              }
            },
            "machineType": {
              "description": "GCP-specific machine type",
              "type": "string"
            },
            "numNodes": {
              "description": "Number of nodes for GCP",
              "type": "integer"
            },
            "nodeSize": {
              "description": "AWS-specific node size",
              "type": "string"
            },
            "nodeCount": {
              "description": "Number of nodes for AWS",
              "type": "integer"
            },
            "vmSize": {
              "description": "Azure-specific VM size",
              "type": "string"
            },
            "sshPublicKey": {
              "description": "Azure-specific SSH public key",
              "type": "string"
            }
          },
          "additionalProperties": false
        },
        "coreServices": {
          "description": "Configuration for core platform services (overrides template)",
          "$ref": "#/definitions/coreServicesSpec"
        },
        "addons": {
          "description": "List of addons to install (merges with template addons)",
          "type": "array",
          "items": {
            "$ref": "#/definitions/addonConfig"
          }
        }
      },
      "required": [
        "provider"
      ],
      "additionalProperties": false
    },
    "coreServicesSpec": {
      "description": "Configuration for core platform services like CNI, Ingress, Git, CD",
      "type": "object",
      "properties": {
        "cilium": { "$ref": "#/definitions/helmChartConfig" },
        "nginx": { "$ref": "#/definitions/helmChartConfig" },
        "gitea": { "$ref": "#/definitions/helmChartConfig" },
        "argocd": { "$ref": "#/definitions/helmChartConfig" },
        "values": {
          "description": "Common Helm values merged into each core service chart defined above",
          "type": "object",
          "additionalProperties": true
        },
        "gitProvider": {
          "description": "The Git provider to use for the Adhar platform",
          "type": "string",
          "enum": ["gitea", "gitlab", "github", "bitbucket"],
          "default": "gitea"
        }
      },
      "additionalProperties": false
    },
    "addonConfig": {
      "description": "Configuration for a single addon",
      "type": "object",
      "properties": {
        "name": {
          "description": "Unique name for the addon within the environment",
          "type": "string",
          "minLength": 1
        },
        "chart": {
          "description": "Helm chart details for the addon",
          "$ref": "#/definitions/chartSpec"
        },
        "values": {
          "description": "Helm values specific to this addon installation",
          "type": "object",
          "additionalProperties": true
        },
        "targetNamespace": {
          "description": "Namespace to install the addon into",
          "type": "string"
        },
        "createNamespace": {
          "description": "Whether to create the target namespace if it doesn't exist",
          "type": "boolean",
          "default": false
        }
      },
      "required": [
        "name",
        "chart"
      ],
      "additionalProperties": false
    },
    "helmChartConfig": {
      "description": "Configuration for a Helm chart deployment, including chart details and values",
      "type": "object",
      "properties": {
        "chart": {
          "$ref": "#/definitions/chartSpec"
        },
        "values": {
          "description": "Helm values specific to this chart installation",
          "type": "object",
          "additionalProperties": true
        }
      },
      "required": [
        "chart"
      ],
      "additionalProperties": false
    },
    "chartSpec": {
      "description": "Helm chart specification (repository, name, version)",
      "type": "object",
      "properties": {
        "repoURL": {
          "description": "URL of the Helm repository",
          "type": "string",
          "format": "uri",
          "pattern": "^https?://"
        },
        "name": {
          "description": "Name of the chart in the repository",
          "type": "string",
          "minLength": 1
        },
        "version": {
          "description": "Version of the chart to install",
          "type": "string",
          "minLength": 1
        }
      },
      "required": [
        "repoURL",
        "name",
        "version"
      ],
      "additionalProperties": false
    }
  }
}
