apiVersion: v1
kind: ConfigMap
metadata:
  name: coredns-conf-default
  namespace: kube-system
data:
  default.conf: |
    # Goal: rewrite the platform host (and its subdomains) so that in-cluster
    # clients reach services via the SAME FQDN as external access. The platform
    # uses the Cilium Gateway (it replaced ingress-nginx), so the host resolves
    # to the generated cilium-gateway-adhar-gateway Service in adhar-system.

    # subdomains, e.g. gitea.adhar.localtest.me -> the Cilium Gateway Service
    rewrite stop {
        name regex (.*)\.{{ .Host }} cilium-gateway-adhar-gateway.adhar-system.svc.cluster.local answer auto
    }

    # the bare host (e.g. adhar.localtest.me, used by the Keycloak OIDC issuer)
    rewrite name exact {{ .Host }} cilium-gateway-adhar-gateway.adhar-system.svc.cluster.local